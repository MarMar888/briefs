# Briefs pipeline secrets for the Oracle bridge VM.
#   cp .env.example .env   then fill in the blanks.
# This file is git-ignored when named ".env" — never commit real tokens.

# --- Prod Turso DB (writes straight to your live leads dashboard) ---
TURSO_DB_URL=libsql://briefs-marmar888.aws-us-east-2.turso.io
TURSO_AUTH_TOKEN=          # mint one on your Mac:  turso db tokens create briefs

# --- Required for the pipeline ---
OPENROUTER_API_KEY=        # same value your GitHub secret uses
DOMAINS_MONITOR_TOKEN=     # same value your GitHub secret uses (daily firehose pull)

# --- Optional: email digest of new matches (leave blank to skip emails) ---
RESEND_API_KEY=
ALERT_EMAIL=
ALERT_FROM=

# --- Optional: off-site search for Lead Audit / enrich (no-ops if unset) ---
SERPAPI_API_KEY=
BRAVE_SEARCH_API_KEY=
