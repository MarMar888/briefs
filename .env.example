# Active market vertical: outdoor (default, OSI) | construction (Ramp SDR leads).
# Selects keywords/prompts/audit rules and the industry stamped on every lead row.
# Per-run override: run.py --vertical / enricher.py --vertical (CI sets it per matrix job).
VERTICAL=outdoor
OPENROUTER_API_KEY=your_key_here
SERPAPI_KEY=your_key_here
DOMAIN_DB_PATH=domain_leads.sqlite3
TURSO_DB_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your_turso_token
DOMAINS_MONITOR_TOKEN=your_domains_monitor_token
FIRECRAWL_API_KEY=fc_your_key
RESEND_API_KEY=re_your_key
ALERT_EMAIL=marleyhansenbarrett@gmail.com
ALERT_FROM=OSI Lead Monitor <alerts@your-domain.com>
